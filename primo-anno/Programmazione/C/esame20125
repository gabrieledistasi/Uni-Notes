/*Si scriva una funzione avente il seguente prototipo:
char *prefix(char *a, int n);
dove a è una stringa. La funzione deve ritornare una nuova stringa contenente i primi n
caratteri di a . Nel caso in cui n sia maggiore della lunghezza di a , la stringa deve ritornare
una copia di a.*/

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

char *prefix(char *a, int n){

    int len = strlen(a); 

    char *b = malloc(sizeof(char)*(len+1)); 
    if(b==NULL){
        return NULL; 
    }

    if(n >= len){
        n = len;   
    }

    for(int i = 0; i < n; i++){

        b[i] = a[i];

    }

    b[n] = '\0'; 

    return b; 

}